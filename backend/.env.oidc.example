# Local OIDC (Keycloak) example for AUTH_MODE=hybrid.
#
# Start Keycloak:
#   docker compose -f ../docker-compose.oidc.yml up -d
#
# Then run backend in dev mode (OIDC redirect is http://...):
#   cd backend && cp .env.oidc.example .env && npm run dev

NODE_ENV=development
PORT=8000

# Allow the local frontend dev server origin (Vite default)
FRONTEND_URL=http://localhost:5173

AUTH_MODE=hybrid

OIDC_PROVIDER_NAME=Keycloak
OIDC_ISSUER_URL=http://localhost:8080/realms/excalidash
OIDC_CLIENT_ID=excalidash
OIDC_CLIENT_SECRET=excalidash-local-secret
OIDC_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback

# Optional, but recommended if you restart the backend often and want stable cookies.
# JWT_SECRET=change-me-to-a-long-random-string
# CSRF_SECRET=change-me-to-a-long-random-string

